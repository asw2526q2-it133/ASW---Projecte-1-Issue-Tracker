<div class="login-container">
  <div class="login-box">
    <h2 class="login-title">Identificació Requerida</h2>
    <p class="login-subtitle">Si us plau, inicia sessió amb el teu compte de GitHub per utilitzar aquesta aplicació.</p>
    
    <%# Botón de Login con GitHub %>
    <%= button_to user_github_omniauth_authorize_path, data: { turbo: false }, class: "btn-github-login" do %>
      Sign in with GitHub
    <% end %>
  </div>
</div>