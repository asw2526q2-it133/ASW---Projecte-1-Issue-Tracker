<div class="issue-container">
  <%= form_with(model: @issue, local: true, class: "issue-form", multipart: true) do |f| %>
    
    <%# Manejo de errores %>
    <% if @issue.errors.any? %>
      <div style="background: #fee; color: #900; border: 1px solid #900; padding: 15px; margin-bottom: 20px; border-radius: 4px;">
        <strong>Error! Could not save:</strong>
        <ul style="margin: 5px 0 0 20px;">
          <% @issue.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-layout">
      
      <%# Columna Principal %>
      <div class="main-column">
        <div class="field">
          <%= f.text_field :subject, placeholder: "Subject", class: "input-subject" %>
        </div>

        <div class="status-dropdown">
          <%= f.collection_select :tag_ids, @tags, :id, :name, 
              { prompt: "+ Add tag" }, { class: "btn-add-tag" } %>
        </div>

        <div class="field">
          <%= f.text_area :description, 
              placeholder: "Please add descriptive text to help others better understand this issue", 
              class: "input-description" %>
        </div>

        <%# Caja de Adjuntos (100% HTML/CSS) %>
        <div class="attachments-box">
          <div class="att-header" style="background:#ebf1f3;padding:8px 14px;border-radius:4px 4px 0 0;border-bottom:1px solid #dde6ea;">
            <span style="font-size:13px;font-weight:500;">Attachments</span>
          </div>

          <div style="padding: 20px; border:2px dashed #ccc; border-top:none; border-radius:0 0 4px 4px; background:#fff; text-align:center;">
            <div style="color:#7c8b9a; font-size:13px; margin-bottom: 15px;">
              Haz clic abajo para seleccionar tus archivos:
            </div>
            
            <%# Input nativo de archivos: visible para que el navegador muestre qué se ha seleccionado %>
            <%= f.file_field :attachments, multiple: true, style: "display: block; margin: 0 auto; max-width: 100%; color: #333;" %>
          </div>
        </div>
      </div>

      <%# Barra Lateral (Sidebar) %>
      <aside class="sidebar">
        <div class="status-dropdown">
          <%= f.collection_select :status_id, @statuses, :id, :name, 
              { prompt: "Select Status" }, 
              { class: "select-status-main" } %>
        </div>

        <div class="status-dropdown">
          <%= f.collection_select :assignee_id, @assignable_users, :id, :name, 
              { prompt: "Assign to" }, { class: "select-assignee" } %>
        </div>

        <div class="meta-item">
          <span class="label">type</span>
          <div class="value">
            <%= f.collection_select :issue_type_id, @types, :id, :name, {}, { class: "meta-select" } %>
          </div>
        </div>

        <div class="meta-item">
          <span class="label">severity</span>
          <div class="value">
            <%= f.collection_select :severity_id, @severities, :id, :name, {}, { class: "meta-select" } %>
          </div>
        </div>

        <div class="meta-item">
          <span class="label">priority</span>
          <div class="value">
            <%= f.collection_select :priority_id, @priorities, :id, :name, {}, { class: "meta-select" } %>
          </div>
        </div>

        <div class="action-icons">
          <div class="calendar-wrapper btn-icon">
            <span>🕒</span>
            <%= f.date_field :due_date, class: "input-fecha-overlay" %>
          </div>
        </div>

        <div class="status-dropdown">
          <span style="display: block; margin-bottom: 4px; color: #666; font-size: 0.9em;">Add Watchers</span>
          <%= f.collection_select :watcher_ids, @assignable_users, :id, :name, 
              {}, 
              { multiple: true, class: "select-assignee" } %>
        </div>
      </aside>
    </div>

    <%# Botón de Envío %>
    <div class="submit-container">
      <%= f.submit "CONFIRM", class: "btn-submit" %>
    </div>
    
  <% end %>
</div>