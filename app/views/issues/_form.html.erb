<div class="issue-container">
  <%= form_with(model: @issue, local: true, class: "issue-form") do |f| %>
    <% if @issue.errors.any? %>
      <div style="background: #fee; color: #900; border: 1px solid #900; padding: 15px; margin-bottom: 20px; border-radius: 4px;">
        <strong>Error! Could not save:</strong>
        <ul style="margin: 5px 0 0 20px;">
          <% @issue.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-layout">
      <div class="main-column">
        <%# ASUNTO %>
        <div class="field">
          <%= f.text_field :subject, placeholder: "Subject", class: "input-subject", required: true %>
        </div>

        <%# TAGS (Corregido para permitir selección múltiple estilo Taiga) %>
        <div class="status-dropdown">
          <label style="font-size: 11px; color: #8a9ab0; font-weight: bold; text-transform: uppercase;">Tags</label>
          <%= f.collection_select :tag_ids, @tags, :id, :name, 
              {}, 
              { multiple: true, class: "select-tags-multi", style: "width: 100%; margin-top: 5px;" } %>
        </div>

        <%# DESCRIPCIÓN %>
        <div class="field" style="margin-top: 20px;">
          <%= f.text_area :description, 
              placeholder: "Please add descriptive text to help others better understand this issue", 
              class: "input-description" %>
        </div>

        <%# ADJUNTOS (Simulado según tu estructura) %>
        <div class="attachments-section">
          <div class="attachments-header">
            <span>Attachments</span>
            <button type="button" class="btn-plus">+</button>
          </div>
        </div>
      </div>

      <aside class="sidebar">
        <%# ESTADO PRINCIPAL %>
        <div class="status-dropdown">
          <span class="label" style="font-size: 11px; color: #8a9ab0; font-weight: bold; text-transform: uppercase;">Status</span>
          <%= f.collection_select :status_id, @statuses, :id, :name, 
              { prompt: "Select Status" }, 
              { class: "select-status-main", required: true } %>
        </div>

        <%# ASIGNAR A (Cambiado de assignee_id a user_id según tu schema) %>
        <div class="status-dropdown" style="margin-top: 15px;">
          <span class="label" style="font-size: 11px; color: #8a9ab0; font-weight: bold; text-transform: uppercase;">Assignee</span>
          <%= f.collection_select :user_id, @assignable_users, :id, :name, 
              { prompt: "Assign to" }, { class: "select-assignee" } %>
        </div>

        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">

        <%# META ITEMS (Type, Severity, Priority) %>
        <div class="meta-item">
          <span class="label">Type</span>
          <div class="value">
            <%= f.collection_select :issue_type_id, @types, :id, :name, { prompt: "Select Type" }, { class: "meta-select", required: true } %>
          </div>
        </div>

        <div class="meta-item">
          <span class="label">Severity</span>
          <div class="value">
            <%= f.collection_select :severity_id, @severities, :id, :name, { prompt: "Select Severity" }, { class: "meta-select", required: true } %>
          </div>
        </div>

        <div class="meta-item">
          <span class="label">Priority</span>
          <div class="value">
            <%= f.collection_select :priority_id, @priorities, :id, :name, { prompt: "Select Priority" }, { class: "meta-select", required: true } %>
          </div>
        </div>

        <%# DUE DATE %>
        <div class="action-icons" style="margin-top: 20px;">
          <span class="label" style="font-size: 11px; color: #8a9ab0; font-weight: bold; text-transform: uppercase; display: block; margin-bottom: 5px;">Due Date</span>
          <div class="calendar-wrapper btn-icon" style="display: flex; align-items: center; gap: 10px;">
            <span>🕒</span>
            <%= f.date_field :due_date, class: "input-fecha-overlay" %>
          </div>
        </div>

        <div class="status-dropdown">
          <span style="display: block; margin-bottom: 4px; color: #666; font-size: 0.9em;">Add Watchers</span>
          <%= f.collection_select :watcher_ids, @assignable_users, :id, :name, 
              {}, 
              { multiple: true, class: "select-assignee" } %>
        </div>
      </aside>
    </div>

    <div class="submit-container" style="margin-top: 30px; text-align: right; border-top: 1px solid #e0e6ed; padding-top: 20px;">
      <%= link_to "CANCEL", issues_path, style: "color: #8a9ab0; text-decoration: none; margin-right: 20px; font-size: 13px; font-weight: bold;" %>
      <%= f.submit "CONFIRM", class: "btn-submit" %>
    </div>
  <% end %>
</div>