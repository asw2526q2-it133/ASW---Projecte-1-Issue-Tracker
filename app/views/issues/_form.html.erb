<div class="issue-container">
  <%= form_with(model: @issue, local: true, class: "issue-form", multipart: true) do |f| %>
    
    <%# error manegment dins la vista %>
    <% if @issue.errors.any? %>
      <div style="background: #fee; color: #900; border: 1px solid #900; padding: 15px; margin-bottom: 20px; border-radius: 4px;">
        <strong>Error! Could not save:</strong>
        <ul style="margin: 5px 0 0 20px;">
          <% @issue.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-layout">
      
      <div class="main-column">
        <%# subject %>
        <div class="field">
          <%= f.text_field :subject, placeholder: "Subject", class: "input-subject", required: true %>
        </div>

        <%# tags %>
        <div class="status-dropdown">
          <label style="font-size: 11px; color: #8a9ab0; font-weight: bold; text-transform: uppercase;">Tags</label>
          <%= f.collection_select :tag_ids, @tags, :id, :name, 
              {}, 
              { multiple: true, class: "select-tags-multi", style: "width: 100%; margin-top: 5px;" } %>
        </div>

        <%# descripcio %>
        <div class="field" style="margin-top: 20px;">
          <%= f.text_area :description, 
              placeholder: "Please add descriptive text to help others better understand this issue", 
              class: "input-description" %>
        </div>

        <%# adjunts %>
        <div class="attachments-section" style="margin-top: 20px;">
          <div class="attachments-header" style="background:#ebf1f3;padding:8px 14px;border-radius:4px 4px 0 0;border-bottom:1px solid #dde6ea;">
            <span style="font-size:13px;font-weight:bold;color:#8a9ab0;text-transform:uppercase;">Attachments</span>
          </div>

          <div style="padding: 20px; border:2px dashed #ccc; border-top:none; border-radius:0 0 4px 4px; background:#fff;">
            
            <%# arxius adjuntats %>
            <% if @issue.attachments.attached? %>
              <div style="margin-bottom: 20px; text-align: left;">
                <p style="font-size: 12px; color: #8a9ab0; margin-bottom: 10px; font-weight: bold; text-transform: uppercase;">Archivos guardados:</p>
                
                <% @issue.attachments.each do |file| %>
                  <div style="display: flex; align-items: center; justify-content: space-between; background: #fdfdfd; border: 1px solid #e0e6ed; padding: 8px 12px; margin-bottom: 8px; border-radius: 4px;">
                    
                    <div style="display: flex; align-items: center; gap: 10px; overflow: hidden;">
                      <span style="font-size: 16px;">📎</span>
                      <%= link_to file.filename.to_s, rails_blob_path(file, disposition: "attachment"), target: "_blank", style: "font-size: 13px; color: #008aa8; text-decoration: none; font-weight: bold;" %>
                    </div>
                    
                    <div style="display: flex; align-items: center; gap: 15px;">
                      <%# Mantiene el archivo al guardar %>
                      <%= f.hidden_field :attachments, multiple: true, value: file.signed_id %>
                      
                      <%# eliminar checkbox %>
                      <label style="font-size: 12px; color: #e74c3c; cursor: pointer; display: flex; align-items: center; gap: 4px; font-weight: bold;">
                        <%= check_box_tag "issue[remove_attachments][]", file.id %>
                        Eliminar
                      </label>
                    </div>

                  </div>
                <% end %>
              </div>
              <hr style="border: 0; border-top: 1px dashed #ccc; margin: 20px 0;">
            <% end %>

            <%# pujar nous adjunts %>
            <div style="text-align: center;">
              <div style="color:#7c8b9a; font-size:13px; margin-bottom: 15px;">
                <%= @issue.attachments.attached? ? "Añadir más archivos:" : "Haz clic abajo para seleccionar tus archivos:" %>
              </div>
              <%= f.file_field :attachments, multiple: true, style: "display: block; margin: 0 auto; max-width: 100%; color: #333;" %>
            </div>

          </div>
        </div>
      </div>

      <%# barra latereal %>
      <aside class="sidebar">
        <%# ESTADO PRINCIPAL %>
        <div class="status-dropdown">
          <span class="label" style="font-size: 11px; color: #8a9ab0; font-weight: bold; text-transform: uppercase;">Status</span>
          <%= f.collection_select :status_id, @statuses, :id, :name, 
              { prompt: "Select Status" }, 
              { class: "select-status-main", required: true } %>
        </div>

        <%# assign to %>
        <div class="status-dropdown" style="margin-top: 15px;">
          <span class="label" style="font-size: 11px; color: #8a9ab0; font-weight: bold; text-transform: uppercase;">Assignee</span>
          <%= f.collection_select :user_id, @assignable_users, :id, :name, 
              { prompt: "Assign to" }, { class: "select-assignee" } %>
        </div>

        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">

        <%# assign carecteristiques a la issue (type, severity, priority) %>
        <div class="meta-item">
          <span class="label">Type</span>
          <div class="value">
            <%= f.collection_select :issue_type_id, @types, :id, :name, { prompt: "Select Type" }, { class: "meta-select", required: true } %>
          </div>
        </div>

        <div class="meta-item">
          <span class="label">Severity</span>
          <div class="value">
            <%= f.collection_select :severity_id, @severities, :id, :name, { prompt: "Select Severity" }, { class: "meta-select", required: true } %>
          </div>
        </div>

        <div class="meta-item">
          <span class="label">Priority</span>
          <div class="value">
            <%= f.collection_select :priority_id, @priorities, :id, :name, { prompt: "Select Priority" }, { class: "meta-select", required: true } %>
          </div>
        </div>

        <%# data venciment %>
        <div class="action-icons" style="margin-top: 20px;">
          <span class="label" style="font-size: 11px; color: #8a9ab0; font-weight: bold; text-transform: uppercase; display: block; margin-bottom: 5px;">Due Date</span>
          <div class="calendar-wrapper btn-icon" style="display: flex; align-items: center; gap: 10px;">
            <span>🕒</span>
            <%= f.date_field :due_date, class: "input-fecha-overlay" %>
          </div>
        </div>

        <div class="status-dropdown" style="margin-top: 20px;">
          <span style="display: block; margin-bottom: 4px; color: #8a9ab0; font-size: 11px; font-weight: bold; text-transform: uppercase;">Add Watchers</span>
          <%= f.collection_select :watcher_ids, @assignable_users, :id, :name, 
              {}, 
              { multiple: true, class: "select-assignee" } %>
        </div>
      </aside>
    </div>

    <div class="submit-container" style="margin-top: 30px; text-align: right; border-top: 1px solid #e0e6ed; padding-top: 20px;">
      <%= link_to "CANCEL", issues_path, style: "color: #8a9ab0; text-decoration: none; margin-right: 20px; font-size: 13px; font-weight: bold;" %>
      <%= f.submit "CONFIRM", class: "btn-submit" %>
    </div>
    
  <% end %>
</div>