<% if issues.any? %>
  <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95em;">
    <thead>
      <tr style="border-bottom: 2px solid #eaeaea; color: #999; font-size: 0.85em; text-transform: uppercase;">
        <th style="padding: 10px 5px;">T</th>
        <th style="padding: 10px 5px;">S</th>
        <th style="padding: 10px 5px;">P</th>
        <th style="padding: 10px 5px;">Issue</th>
        <th style="padding: 10px 5px; text-align: right;">Status</th>
        <th style="padding: 10px 5px; text-align: right;">Modified</th>
      </tr>
    </thead>
    <tbody>
      <% issues.each do |issue| %>
        <tr style="border-bottom: 1px solid #f5f5f5;">
          
          <td style="padding: 12px 5px;">
            <div style="width: 14px; height: 14px; border-radius: 50%; background-color: <%= issue.issue_type&.color || '#ccc' %>;" title="<%= issue.issue_type&.name %>"></div>
          </td>
          
          <td style="padding: 12px 5px;">
            <div style="width: 14px; height: 14px; border-radius: 50%; background-color: <%= issue.severity&.color || '#ccc' %>;" title="<%= issue.severity&.name %>"></div>
          </td>
          
          <td style="padding: 12px 5px;">
            <div style="width: 14px; height: 14px; border-radius: 50%; background-color: <%= issue.priority&.color || '#ccc' %>;" title="<%= issue.priority&.name %>"></div>
          </td>
          
          <td style="padding: 12px 5px;">
            <%= link_to "##{issue.id} #{issue.subject}", issue_path(issue), style: "text-decoration: none; color: #0097a7; font-weight: 500;" %>
          </td>
          
          <td style="padding: 12px 5px; text-align: right; color: <%= issue.status&.color || '#333' %>;">
            <%= issue.status&.name %>
          </td>
          
          <td style="padding: 12px 5px; text-align: right; color: #666; font-size: 0.9em;">
            <%= issue.updated_at.strftime("%d %b %Y") %>
          </td>

        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p style="color: #666; font-style: italic; padding: 15px 0;">No hi ha cap issue en aquesta secció.</p>
<% end %>