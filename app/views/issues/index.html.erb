<style>
  html, body {
    height: 100%;
    margin: 0;
    overflow: hidden;
  }
  .sort-link {
    color: inherit;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    gap: 5px;
  }
  .sort-link:hover { color: #008aa8; }
</style>

<p style="color: green; position: absolute; top: 10px; right: 10px; z-index: 1000;"><%= notice %></p>

<div class="taiga-container" style="display: flex; flex-direction: column; height: 100vh; width: 100%; font-family: sans-serif; background-color: #f6f8f9;">
  
  <header class="issues-header" style="display: flex; justify-content: space-between; align-items: center; padding: 15px 30px; background: #fff; border-bottom: 1px solid #e0e6ed; flex-shrink: 0;">
    <h1 style="color: #008aa8; font-size: 24px; font-weight: 300; margin: 0;">Issues</h1>
    <%= link_to "+ NEW ISSUE", new_issue_path, style: "background: #5adad1; color: #fff; padding: 8px 18px; border-radius: 3px; text-decoration: none; font-weight: bold; font-size: 13px;" %>
  </header>

  <%# --- BARRA DE BÚSQUEDA --- %>
  <div class="search-bar-wrapper" style="padding: 10px 30px; background: #fff; border-bottom: 1px solid #e0e6ed; flex-shrink: 0; width: 100%; box-sizing: border-box;">
    <%= form_with url: issues_path, method: :get, local: true, style: "display: flex; width: 100%; margin: 0; padding: 0;" do |form| %>
      <% ["types", "statuses", "priorities", "severities"].each do |param_name| %>
        <% if params[param_name].is_a?(Array) %>
          <% params[param_name].each do |val| %>
            <%= hidden_field_tag "#{param_name}[]", val %>
          <% end %>
        <% end %>
      <% end %>

      <div style="display: flex; width: 100%; border: 1px solid #c2cfd6; border-radius: 4px; overflow: hidden; background: #fff;">
        <%= form.text_field :search, value: params[:search], 
            placeholder: "Filter / Sort / Search Issues...", 
            style: "flex: 1; padding: 12px 15px; border: none; outline: none; font-size: 14px; background: transparent;" %>
        <button type="submit" style="background: #f8f9fa; border: none; border-left: 1px solid #c2cfd6; padding: 0 20px; cursor: pointer; color: #73818f;">🔍</button>
      </div>
    <% end %>
  </div>

  <div class="main-content-wrapper" style="display: flex; flex: 1; overflow: hidden; padding: 20px 30px; gap: 20px;">
    
    <%# --- SIDEBAR DE FILTROS DINÁMICA --- %>
    <aside class="filters-sidebar" style="width: 220px; flex-shrink: 0; background: #fff; border: 1px solid #e0e6ed; padding: 20px; border-radius: 4px; overflow-y: auto;">
      <%= form_with url: issues_path, method: :get, local: true do |form| %>
        <%= form.hidden_field :search, value: params[:search] if params[:search].present? %>
        <%= form.hidden_field :sort, value: params[:sort] if params[:sort].present? %>
        <%= form.hidden_field :direction, value: params[:direction] if params[:direction].present? %>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid #eee; padding-bottom: 10px;">
          <span style="font-weight: bold; font-size: 12px; color: #3c4b5f;">FILTERS</span>
          <%= link_to "Clear", issues_path, style: "font-size: 11px; color: #e74c3c; text-decoration: none; font-weight: bold;" %>
        </div>

        <% 
          filters_config = [
            { label: "TYPE",     param: "types",      options: IssueType.pluck(:name) },
            { label: "STATUS",   param: "statuses",   options: Status.pluck(:name) },
            { label: "PRIORITY", param: "priorities", options: Priority.pluck(:name) },
            { label: "SEVERITY", param: "severities", options: Severity.pluck(:name) }
          ]
        %>

        <% filters_config.each do |config| %>
          <div style="margin-bottom: 20px;">
            <p style="font-size: 11px; font-weight: bold; color: #8a9ab0; text-transform: uppercase; margin-bottom: 10px;"><%= config[:label] %></p>
            <% config[:options].each do |opt| %>
              <label style="display: flex; align-items: center; font-size: 13px; margin-bottom: 8px; cursor: pointer; color: #3c4b5f;">
                <%= check_box_tag "#{config[:param]}[]", opt, params[config[:param]]&.include?(opt), onchange: "this.form.submit();", style: "margin-right: 10px;" %> 
                <%= opt %>
              </label>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </aside>

    <%# --- TABLA DE RESULTADOS --- %>
    <div class="table-container" style="flex: 1; background: #fff; border: 1px solid #e0e6ed; border-radius: 4px; display: flex; flex-direction: column; overflow: hidden;">
      
      <div class="table-header" style="display: flex; background: #fdfdfd; border-bottom: 1px solid #e0e6ed; padding: 15px 0; font-size: 11px; font-weight: bold; color: #8a9ab0; flex-shrink: 0;">
        <%# CAMBIAMOS LOS NOMBRES PARA QUE TENGAN EL _ID %>
        <div style="width: 60px; text-align: center;"><%= sortable "issue_type_id", "TYPE" %></div>        
        <div style="width: 100px; text-align: center;"><%= sortable "severity_id", "SEVERITY" %></div>
        <div style="width: 100px; text-align: center;"><%= sortable "priority_id", "PRIORITY" %></div>
        <div style="flex: 1; padding-left: 20px; text-align: left;"><%= sortable "subject", "ISSUE" %></div>
        <div style="width: 120px; text-align: center;"><%= sortable "status_id", "STATUS" %></div>
        <div style="width: 120px; text-align: center;"><%= sortable "updated_at", "MODIFIED" %></div>
        <div style="width: 100px; text-align: center;"><%= sortable "due_date", "DUE DATE" %></div>
        <div style="width: 80px; text-align: center;">ASSIGN</div>
      </div>

      <div class="table-body" style="flex: 1; overflow-y: auto;">
        <% if @issues.any? %>
          <% @issues.each do |issue| %>
            <div class="issue-row" style="display: flex; align-items: center; padding: 15px 0; border-bottom: 1px solid #f0f3f5; font-size: 14px;">
              
              <div style="width: 60px; display: flex; justify-content: center;">
                <span style="height: 10px; width: 10px; background-color: <%= issue.issue_type&.color || '#ccc' %>; border-radius: 50%;" title="<%= issue.issue_type&.name %>"></span>
              </div>
              <div style="width: 100px; display: flex; justify-content: center;">
                <span style="height: 10px; width: 10px; background-color: <%= issue.severity&.color || '#ccc' %>; border-radius: 50%;" title="<%= issue.severity&.name %>"></span>
              </div>
              <div style="width: 100px; display: flex; justify-content: center;">
                <span style="height: 10px; width: 10px; background-color: <%= issue.priority&.color || '#ccc' %>; border-radius: 50%;" title="<%= issue.priority&.name %>"></span>
              </div>
              
              <div style="flex: 1; padding-left: 20px;">
                <span style="color: #008aa8; font-weight: bold; margin-right: 8px;">#<%= issue.id %></span>
                <%= link_to issue.subject, issue, style: "text-decoration: none; color: #20242a; font-weight: 500;" %>
              </div>

              <div style="width: 120px; display: flex; justify-content: center;">
                <span style="background-color: <%= issue.status&.color || '#e1f5fe' %>; color: #fff; padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: bold; text-transform: uppercase;">
                  <%= issue.status&.name || "New" %>
                </span>
              </div>

              <div style="width: 120px; text-align: center; color: #73818f; font-size: 13px;">
                <%= issue.updated_at.strftime("%d %b %Y") %>
              </div>

              <div style="width: 100px; text-align: center; font-size: 13px; color: #73818f;">
                <%= issue.due_date&.strftime("%d %b %Y") || "-" %>
              </div>

              <div style="width: 80px; display: flex; justify-content: center;">
                <div style="width: 30px; height: 30px; background: #cfd8dc; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold;">
                  <%= issue.user&.name&.first&.upcase || "?" %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div style="padding: 100px; text-align: center; color: #8a9ab0;">No hay resultados con los filtros aplicados.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>