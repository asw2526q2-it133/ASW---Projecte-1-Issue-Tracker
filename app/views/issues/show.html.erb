<style>
  /* Lógica CSS para alternar vistas sin JS */
  #view-grid:checked ~ .view-content #show-att-grid { display: grid !important; }
  #view-grid:checked ~ .view-content #show-att-list { display: none !important; }
  #view-list:checked ~ .view-content #show-att-list { display: flex !important; }
  #view-list:checked ~ .view-content #show-att-grid { display: none !important; }

  /* Estilos para que los labels parezcan botones */
  .view-tab {
    background: none; border: none; cursor: pointer; padding: 4px; border-radius: 4px; 
    font-size: 14px; line-height: 1; color: #666; border: 0.5px solid transparent;
  }
  #view-grid:checked ~ .attachments-header .label-grid { background: white; border-color: #ccc; color: #000; }
  #view-list:checked ~ .attachments-header .label-list { background: white; border-color: #ccc; color: #000; }
  
  .hidden-radio { display: none; }
</style>

<p style="color: green"><%= notice %></p>

<div class="taiga-show-container">
  <div class="issue-main-content">
    <div class="issue-header-show">
      <span class="issue-number-big">#<%= @issue.id %></span>
      <h1><%= @issue.subject %></h1>
    </div>

    <div class="issue-description-box">
      <h3>Description</h3>
      <div class="description-text">
        <%= @issue.description.presence || "No description provided." %>
      </div>
    </div>

    <div class="attachments-box" style="margin-top: 20px;">
      <input type="radio" name="view_type" id="view-grid" class="hidden-radio" checked>
      <input type="radio" name="view_type" id="view-list" class="hidden-radio">

      <div class="attachments-header" style="display:flex;justify-content:space-between;align-items:center;background:#ebf1f3;padding:8px 14px;border-radius:4px 4px 0 0;border-bottom:1px solid #dde6ea;">
        <span style="font-size:13px;font-weight:500;">
          <%= @issue.attachments.count %> Attachment<%= @issue.attachments.count != 1 ? 's' : '' %>
        </span>
        <div style="display:flex;gap:4px;">
          <label for="view-grid" class="view-tab label-grid" title="Grid View">&#9783;</label>
          <label for="view-list" class="view-tab label-list" title="List View">&#9776;</label>
        </div>
      </div>

      <div class="view-content" style="min-height:60px;padding:12px;border:2px dashed #ccc;border-top:none;border-radius:0 0 4px 4px;background:#fff;">
        <% if @issue.attachments.attached? %>

          <%# Vista lista %>
          <div id="show-att-list" style="display:none;flex-direction:column;">
            <% @issue.attachments.each do |file| %>
              <div style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-bottom:1px solid #eee;font-size:13px;">
                <span style="font-size:14px;color:#666;">📎</span>
                <%= link_to file.filename.to_s, rails_blob_path(file, disposition: "attachment"),
                    style: "flex:1;color:#008aa8;font-weight:500;word-break:break-all;text-decoration:none;" %>
                <span style="color:#666;font-size:12px;min-width:55px;text-align:right;"><%= number_to_human_size(file.byte_size) %></span>
              </div>
            <% end %>
          </div>

          <%# Vista grid %>
          <div id="show-att-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:8px;">
            <% @issue.attachments.each do |file| %>
              <%= link_to rails_blob_path(file, disposition: "attachment"),
                  style: "display:flex;flex-direction:column;align-items:center;gap:4px;padding:8px;border:1px solid #eee;border-radius:6px;text-decoration:none;" do %>
                <span style="font-size:28px;line-height:1;">📎</span>
                <span style="font-size:10px;color:#666;text-align:center;word-break:break-all;max-width:72px;"><%= file.filename %></span>
                <span style="font-size:10px;color:#999;"><%= number_to_human_size(file.byte_size) %></span>
              <% end %>
            <% end %>
          </div>

        <% else %>
          <div style="color:#7c8b9a;font-size:13px;text-align:center;padding:16px 0;">No attachments.</div>
        <% end %>
      </div>
    </div>

    <div class="show-actions">
      <%= link_to "Edit this issue", edit_issue_path(@issue), class: "btn-edit" %>
      <%= link_to "Back to issues", issues_path, class: "btn-back" %>
      <%# Nota: Eliminamos data-confirm porque requiere JS de Rails (UJS/Turbo) %>
      <%= button_to "Delete", @issue, method: :delete, class: "btn-delete" %>
    </div>
  </div>

  <aside class="issue-sidebar">
    <div class="sidebar-item">
      <label>STATUS</label>
      <div class="status-badge"><%= @issue.status&.name || "New" %></div>
    </div>
    <div class="sidebar-item">
      <label>TYPE</label>
      <div class="meta-value">
        <span class="dot" style="background-color: <%= @issue.issue_type&.color %>"></span>
        <%= @issue.issue_type&.name || "Bug" %>
      </div>
    </div>
    <div class="sidebar-item">
      <label>SEVERITY</label>
      <div class="meta-value">
        <span class="dot" style="background-color: <%= @issue.severity&.color %>"></span>
        <%= @issue.severity&.name || "Normal" %>
      </div>
    </div>
    <div class="sidebar-item">
      <label>PRIORITY</label>
      <div class="meta-value">
        <span class="dot" style="background-color: <%= @issue.priority&.color %>"></span>
        <%= @issue.priority&.name || "Normal" %>
      </div>
    </div>
    <div class="sidebar-item divider"></div>
    <div class="sidebar-item">
      <label>CREATED BY</label>
      <div class="user-info">
        <% if @issue.user %>
          <div class="avatar"><%= @issue.user.name.first.upcase %></div>
          <span><%= @issue.user.name %></span>
        <% else %>
          <div class="avatar">?</div>
          <span>Sin asignar</span>
        <% end %>
      </div>
    </div>
    <div class="sidebar-item">
      <label>MODIFIED</label>
      <div class="meta-value small"><%= @issue.updated_at.strftime("%d %b %Y, %H:%M") %></div>
    </div>
  </aside>
</div>