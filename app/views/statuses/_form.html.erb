<%= form_with(model: status) do |form| %>
  <% if status.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(status.errors.count, "error") %> prohibited this status from being saved:</h2>
      <ul>
        <% status.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div style="margin-bottom: 10px;">
    <%= form.label :name, "Nombre del Estado", style: "display: block; font-weight: bold;" %>
    <%= form.text_field :name %>
  </div>

  <%# --- AQUÍ VA EL COLOR PICKER --- %>
  <div style="margin-bottom: 10px;">
    <%= form.label :color, "Color del Estado", style: "display: block; font-weight: bold;" %>
    <%= form.color_field :color, style: "width: 100px; height: 40px; cursor: pointer; border: 1px solid #ddd; border-radius: 4px;" %>
  </div>

  <div>
    <%= form.submit "Guardar Estado" %>
  </div>
<% end %>